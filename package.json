{
  "name": "cider-music",
  "version": "0.1.0",
  "description": "Apple Music CLI for power users and AI agents",
  "type": "module",
  "bin": {
    "cider-music": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/cider-music",
    "link": "bun link",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun test"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
